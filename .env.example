TRUTH_ENGINE_DATABASE_URL=sqlite:///./truth_engine.db
TRUTH_ENGINE_TEMPORAL_HOST=localhost:7233
TRUTH_ENGINE_TEMPORAL_NAMESPACE=default
TRUTH_ENGINE_TEMPORAL_TASK_QUEUE=truth-engine
TRUTH_ENGINE_PROMPT_VERSION=live-v1

# LiteLLM API key — used for all LLM calls.
# LiteLLM routes to the correct provider based on the model prefix
# (e.g. openai/gpt-4.1, anthropic/claude-3, etc.)
TRUTH_ENGINE_LITELLM_API_KEY=
TRUTH_ENGINE_AGENT_MAX_TOOL_ROUNDS=100

# Model tier defaults (LiteLLM format: provider/model-name)
TRUTH_ENGINE_TIER1_MODEL=openai/gpt-4.1-mini
TRUTH_ENGINE_TIER2_MODEL=openai/gpt-4.1
TRUTH_ENGINE_TIER3_MODEL=openai/gpt-4.1

# Optional: LiteLLM proxy / gateway (for centralized routing, caching, rate limiting)
# TRUTH_ENGINE_LITELLM_API_BASE=http://localhost:4000

TRUTH_ENGINE_SERPER_API_KEY=
TRUTH_ENGINE_REDDIT_CLIENT_ID=
TRUTH_ENGINE_REDDIT_CLIENT_SECRET=
TRUTH_ENGINE_REDDIT_USER_AGENT=truth-engine/0.1
